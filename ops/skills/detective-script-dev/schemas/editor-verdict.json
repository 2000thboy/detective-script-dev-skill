{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Editor Verdict",
  "description": "Final aggregated decision from the editor judge",
  "type": "object",
  "required": ["judge_id", "chapter", "verdict", "revision_checklist", "provider", "model", "owner", "prompt_version", "created_at"],
  "properties": {
    "judge_id": {
      "type": "string",
      "description": "Always editor-judge"
    },
    "chapter": {
      "type": "string"
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "needs_revision", "reject"]
    },
    "provider": { "type": "string" },
    "model": { "type": "string" },
    "owner": { "type": "string" },
    "prompt_version": { "type": "string" },
    "created_at": { "type": "string" },
    "derived_from_lock_hash": { "type": "string" },
    "consensus_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "issue": { "type": "string" },
          "agreed_by": {
            "type": "array",
            "items": { "type": "string" }
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "major", "minor"]
          }
        }
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "issue": { "type": "string" },
          "disagreement": { "type": "string" },
          "reviewers": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "revision_checklist": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["priority", "task"],
        "properties": {
          "priority": {
            "type": "string",
            "enum": ["P0", "P1", "P2"]
          },
          "task": { "type": "string" },
          "from": { "type": "string" }
        }
      }
    },
    "next_action": {
      "type": "string",
      "enum": ["revise_and_resubmit", "proceed", "rollback"]
    }
  }
}
