{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Expert Review Result",
  "description": "Structured output from a review agent",
  "type": "object",
  "required": ["reviewer_id", "chapter", "dimensions", "overall_verdict", "overall_score", "provider", "model", "owner", "prompt_version", "created_at"],
  "properties": {
    "reviewer_id": {
      "type": "string",
      "description": "Agent identifier, e.g. logic-checker"
    },
    "chapter": {
      "type": "string",
      "description": "Chapter identifier, e.g. v1-ch07"
    },
    "dimensions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "verdict", "score"],
        "properties": {
          "name": { "type": "string" },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "0-100 score for this dimension"
          },
          "verdict": {
            "type": "string",
            "enum": ["pass", "fail"]
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "reasoning": { "type": "string" },
          "evidence_quotes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "action_items": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "overall_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Overall 0-100 score"
    },
    "overall_verdict": {
      "type": "string",
      "enum": ["pass", "needs_revision"]
    },
    "pass_threshold": {
      "type": "number",
      "default": 95,
      "description": "Passing threshold for this review"
    },
    "provider": { "type": "string" },
    "model": { "type": "string" },
    "owner": { "type": "string" },
    "prompt_version": { "type": "string" },
    "created_at": { "type": "string" },
    "derived_from_lock_hash": { "type": "string" },
    "critical_issues": {
      "type": "array",
      "items": { "type": "string" }
    },
    "summary": { "type": "string" }
  }
}
