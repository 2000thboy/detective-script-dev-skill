{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Completeness Gate Result",
  "description": "Structured output from the deterministic completeness gate",
  "type": "object",
  "required": ["gate_id", "status", "checks", "created_at"],
  "properties": {
    "gate_id": {
      "type": "string",
      "description": "Always 'completeness-gate'"
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "FAIL"]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check", "status"],
        "properties": {
          "check": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["PASS", "FAIL"]
          },
          "details": { "type": "string" }
        }
      }
    },
    "violations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "created_at": { "type": "string" }
  }
}
